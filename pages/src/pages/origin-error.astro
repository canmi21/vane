---
import Base from "../layouts/base.astro";
import "../styles/global.css";
import { Globe, Route, ArrowRight, AppWindow } from "@lucide/astro";
---

<Base title="Error">
  <section class="flex flex-col h-[100dvh] max-w-5xl mx-auto px-6 py-16 space-y-16">

    <div class="space-y-2">
      <h1 class="text-7xl font-extrabold text-gray-900 text-left">
        %STATUS_CODE% %STATUS_MESSAGE%
      </h1>
      <p class="text-2xl text-muted text-left">
        Something went wrong while processing your request.
      </p>
    </div>

    <div class="flex justify-center">
      <div class="flex flex-col md:flex-row items-center justify-center space-y-8 md:space-y-0 md:space-x-16">
        <div class="flex flex-col items-center space-y-2">
          <Globe class="w-8 h-8 opacity-80" />
          <p class="text-sm text-gray-500">Your Browser</p>
        </div>

        <ArrowRight class="w-6 h-6 opacity-50 md:mt-1" />

        <div class="flex flex-col items-center space-y-2">
          <Route class="w-8 h-8 opacity-80" />
          <p class="text-sm font-medium text-gray-500">Vane Proxy</p>
        </div>

        <ArrowRight class="w-6 h-6 opacity-50 md:mt-1" />

        <div class="flex flex-col items-center space-y-2">
          <AppWindow class="w-8 h-8 opacity-80 text-red-500" />
          <p class="text-sm text-red-600 font-medium">Origin Server</p>
        </div>
      </div>
    </div>

    <div class="flex flex-col md:flex-row md:space-x-12 space-y-8 md:space-y-0">
      <div class="flex-1 space-y-2">
        <h2 class="text-2xl font-semibold text-gray-900">What Happened?</h2>
        <p class="text-muted">
          The request could not be completed because %ERROR_REASON%.
        </p>
      </div>
      <div class="flex-1 space-y-2">
        <h2 class="text-2xl font-semibold text-gray-900">What Can I Do?</h2>
        <p class="text-muted">
          <strong>If you are visitor of this website:</strong> %VISITOR_ACTION%
        </p>
        <p class="text-muted">
          <strong>If you are the site owner:</strong> %OWNER_ACTION%
        </p>
      </div>
    </div>

    <div class="text-center text-sm text-muted space-y-1">
      <div>Request ID: %REQUEST_ID% · %REQUEST_TIMESTAMP% UTC</div>
      <div>
        <span class="ml-4">
          Proxy by <a href="https://vaneproxy.com" class="text-muted">Vane v%VANE_VERSION%</a>
        </span>
        <span class="cursor-pointer" onclick="this.textContent='Request IP: %REQUEST_IP%';">
          · Request IP: Click to reveal
        </span>
      </div>
    </div>

  </section>
</Base>
