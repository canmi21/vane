# Maintainer: Canmi <t@canmi.icu>
pkgname=vane
pkgver=%VERSION%
pkgrel=0
pkgdesc="A flow-based reverse proxy with multi-layer routing and programmable pipelines"
url="https://vaneproxy.com"
arch="%ARCH%"
license="MIT"
depends="musl"
install="$pkgname.post-install"
options="!check !strip"
source="vane
        vane.initd
        LICENSE"

package() {
    # Binary
    install -Dm755 "$srcdir/vane" "$pkgdir/usr/bin/vane"

    # OpenRC init script
    install -Dm755 "$srcdir/vane.initd" "$pkgdir/etc/init.d/vane"

    # License
    install -Dm644 "$srcdir/LICENSE" "$pkgdir/usr/share/licenses/$pkgname/LICENSE"

    # Config directory and files
    install -dm755 "$pkgdir/etc/vane"
    if [ -d "$srcdir/config" ]; then
        cp -r "$srcdir/config"/* "$pkgdir/etc/vane/"
    fi
}

sha512sums="SKIP
SKIP
SKIP"
