		"lucide-react": "^0.562.0",
		"mermaid": "^11.12.2",
		"next": "16.1.1",
		"next-themes": "^0.4.6",
		"react": "^19.2.3",
		"react-dom": "^19.2.3"
	},
	"devDependencies": {
		"@tailwindcss/postcss": "^4.1.18",
		"@types/mdx": "^2.0.13",
		"@types/node": "^24.10.2",
