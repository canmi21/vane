{
  "protocols": [
    {
      "name": "tls",
      "priority": 1,
      "detect": {
        "method": "magic",
        "pattern": "0x16"
      },
      "session": {
        "keepalive": true,
        "timeout": 30000
      },
      "destination": {
        "type": "resolver",
        "resolver": "tls"
      }
    },
    {
      "name": "http",
      "priority": 2,
      "detect": {
        "method": "prefix",
        "pattern": "GET "
      },
      "destination": {
        "type": "forward",
        "forward": {
          "strategy": "serial",
          "targets": [
            {
              "ip": "127.0.0.1",
              "port": 8080
            },
            {
              "ip": "127.0.0.1",
              "port": 8081
            }
          ],
          "fallbacks": [
            {
              "ip": "127.0.0.1",
              "port": 8082
            },
            {
              "ip": "127.0.0.1",
              "port": 8083
            }
          ]
        }
      }
    }
  ]
}